# Streamlit Secrets for Auto Apply Dashboard
# Copy this file to secrets.toml and fill in your API keys
# For local development: place in .streamlit/secrets.toml
# For Streamlit Cloud: Add via Settings → Secrets management

# Anthropic API (for JD parsing and resume tailoring)
anthropic_api_key = "your-anthropic-api-key"

# Adzuna API (for job scraping)
adzuna_app_id = "your-adzuna-app-id"
adzuna_app_key = "your-adzuna-app-key"

# LinkedIn credentials (for LinkedIn scraping)
linkedin_email = "your-linkedin-email"
linkedin_password = "your-linkedin-password"

# Applicant information (for auto-fill)
applicant_first_name = "YourFirstName"
applicant_last_name = "YourLastName"
applicant_email = "your.email@example.com"
applicant_phone = "+1234567890"
applicant_linkedin = "https://linkedin.com/in/yourprofile"
applicant_years_exp = "4"

# Scoring weights (optional customization)
weight_skills = 0.40
weight_experience = 0.30
weight_education = 0.15
weight_location = 0.15

# Thresholds
auto_apply_min_score = 75
min_score_to_tailor = 65

# Company targets
greenhouse_boards = "company1,company2,company3"
lever_companies = "company1,company2"
ashby_companies = "company1,company2"
