# Copy this file to .env and fill in your values. Never commit .env.

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Job sources ───────────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# ── Scraping targets ──────────────────────────────────────────────────────────
# Comma-separated Greenhouse company board tokens
GREENHOUSE_BOARDS=stripe,airbnb,notion

# Comma-separated Lever company slugs
LEVER_COMPANIES=netflix,figma,linear

# ── Fit scoring weights (must sum to 1.0) ─────────────────────────────────────
WEIGHT_SKILLS=0.40
WEIGHT_EXPERIENCE=0.30
WEIGHT_EDUCATION=0.15
WEIGHT_LOCATION=0.15

# ── Automation thresholds ─────────────────────────────────────────────────────
AUTO_APPLY_MIN_SCORE=75     # Only auto-apply if fit score >= this
MIN_SCORE_TO_TAILOR=50      # Only tailor resume if fit score >= this

# ── Paths ─────────────────────────────────────────────────────────────────────
MASTER_RESUME_PATH=resumes/master_resume.pdf
DB_PATH=data/auto_apply.db
LOG_PATH=logs/auto_apply.log
